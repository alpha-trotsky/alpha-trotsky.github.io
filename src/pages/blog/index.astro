---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

// Pull every post, then sort newest-first.
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title="Blog — Your Name" description="Words from Your Name.">
  <h1>Writing</h1>
  <p class="tagline">Trips, short essays, and other appropriate forms of self-expression.</p>

  <ul class="post-list">
    {posts.map((post) => (
      <li>
        <span class="meta">{fmt(post.data.date)}</span>
        <a href={`/blog/${post.id}`}>{post.data.title}</a>
      </li>
    ))}
  </ul>
</Base>
